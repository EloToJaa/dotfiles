	"Drzewo PrzedzialPrzedzial": {
		"prefix": "treesegseg",
		"body": [
			"void Push(int v, ll len) {",
			"\tT[lc] += lazy[v] * len / 2;",
			"\tT[rc] += lazy[v] * len / 2;",
			"\tlazy[lc] += lazy[v];",
			"\tlazy[rc] += lazy[v];",
			"\tlazy[v] = 0;",
			"}",
			"",
			"ll Query(int v, int tl, int tr, int l, int r) {",
			"\tif (l <= tl and tr <= r) return T[v];",
			"\tint tm = (tl + tr) / 2;",
			"\tPush(v, tr-tl+1);",
			"\tll a = 0, b = 0;",
			"\tif(l <= tm) a = Query(lc, tl, tm, l, r);",
			"\tif(r > tm) b = Query(rc, tm+1, tr, l, r);",
			"\tT[v] = T[lc] + T[rc] + lazy[v] * (tr-tl+1);",
			"\treturn a + b;",
			"}",
			"",
			"void Update(int v, int tl, int tr, int l, int r, ll val) {",
			"\tif (l <= tl and tr <= r) {",
			"\t\tT[v] += val * (tr-tl+1);",
			"\t\tlazy[v] += val;",
			"\t\treturn;",
			"\t}",
			"\tint tm = (tl + tr) / 2;",
			"\tPush(v, tr-tl+1);",
			"\tif(l <= tm) Update(lc, tl, tm, l, r, val);",
			"\tif(r > tm) Update(rc, tm + 1, tr, l, r, val);",
			"\tT[v] = T[lc] + T[rc] + lazy[v] * (tr-tl+1);",
			"}"
		],
		"description": "Cpp template"
	},
