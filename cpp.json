	"KolejkaMonotoniczna": {
		"prefix": "monqueue",
		"body": [
			"struct Monqueue {",
			"\tint pops = 0, pushes = 0;",
			"\tdeque<pli> Q;",
			"\tvoid push(const ll &val) {",
			"\t\twhile(!Q.empty() and Q.back().st <= val) Q.pop_back();",
			"\t\tpushes++;",
			"\t\tQ.push_back({val, pushes});",
			"\t}",
			"\tvoid pop() {",
			"\t\tpops++;",
			"\t\tif(!Q.empty() and pops == Q.front().nd) Q.pop_front();",
			"\t}",
			"\tll max() {",
			"\t\tif(Q.empty()) return -INF;",
			"\t\treturn Q.front().st;",
			"\t}",
			"};"
		],
