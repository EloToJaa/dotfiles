	"Modulo": {
		"prefix": "modulo",
		"body": [
			"struct Modulo {",
			"\tll MOD;",
			"\tModulo(ll mod) {",
			"\t\tMOD = mod;",
			"\t}",
			"\tll Moduluj(const ll &a) {",
			"\t\tif(a < MOD) return a;",
			"\t\treturn a % MOD;",
			"\t}",
			"\tll Power(ll a, ll b) {",
			"\t\tif(b == 0) return 1;",
			"\t\tll ans = Power(a, b / 2);",
			"\t\tans = Moduluj(ans * ans);",
			"\t\tif(b & 1) return Moduluj(ans * a);",
			"\t\treturn ans;",
			"\t}",
			"\tll Dodaj(ll a, ll b) {",
			"\t\ta = Moduluj(a), b = Moduluj(b);",
			"\t\tif(a + b >= MOD) return a + b - MOD;",
			"\t\telse return a + b;",
			"\t}",
			"\tll Odejmij(ll a, ll b) {",
			"\t\ta = Moduluj(a), b = Moduluj(b);",
			"\t\tif(a - b < 0) return a - b + MOD;",
			"\t\telse return a - b;",
			"\t}",
			"\tll Mnoz(ll a, ll b) {",
			"\t\ta = Moduluj(a), b = Moduluj(b);",
			"\t\treturn Moduluj(a * b);",
			"\t}",
			"\tll Dziel(ll a, ll b) {",
			"\t\ta = Moduluj(a), b = Moduluj(b);",
			"\t\treturn Moduluj(a * Power(b, MOD - 2));",
			"\t}",
			"} Mod(1e9 + 7);"
		],
		"description": "Cpp template"
	},
	"Hash": {
		"prefix": "hash",
		"body": [
			"struct Hash {",
			"\tvector<pll> Hasz, Pot;",
			"\tint n, m;",
			"\tstring s;",
			"\tvoid Build() {",
			"\t\tconst pii P = {29, 31};",
			"\t\tconst int S = 'a';",
			"\t\tHasz.resize(n + 1, {0, 0});",
			"\t\tPot.resize(m + 1, {0, 0});",
			"\t\tPot[0] = {1, 1};",
			"\t\tFOR(i, 1, m)",
			"\t\t\tPot[i] = {",
			"\t\t\t\tMod.Mnoz(Pot[i - 1].st, P.st),",
			"\t\t\t\tMod.Mnoz(Pot[i - 1].nd, P.nd)",
			"\t\t\t};",
			"\t\tFOR(i, 1, n)",
			"\t\t\tHasz[i] = {",
			"\t\t\t\tMod.Dodaj( Hasz[i - 1].st, Mod.Mnoz(Pot[i].st, (s[i] - S + 1)) ),",
			"\t\t\t\tMod.Dodaj( Hasz[i - 1].nd, Mod.Mnoz(Pot[i].nd, (s[i] - S + 1)) )",
			"\t\t\t};",
			"\t}",
			"\tvoid Init(string input_string, int max_size = -1) {",
			"\t\ts = \"#\" + input_string;",
			"\t\tn = SZ(s) - 1;",
			"\t\tif(max_size == -1) m = n;",
			"\t\telse m = max_size;",
			"\t\tBuild();",
			"\t}",
			"\tpll GetHash(int l = 1, int r = -1) {",
			"\t\tif(r == -1) r = n;",
			"\t\treturn {",
			"\t\t\tMod.Mnoz( Mod.Odejmij(Hasz[r].st, Hasz[l - 1].st), Pot[m - r].st),",
			"\t\t\tMod.Mnoz( Mod.Odejmij(Hasz[r].nd, Hasz[l - 1].nd), Pot[m - r].nd)",
			"\t\t};",
			"\t}",
			"\tint size() {",
			"\t\treturn n;",
			"\t}",
			"};"
		],
		"description": "Cpp template"
	},
