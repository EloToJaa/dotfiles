	"Dijkstra": {
		"prefix": "dijkstra",
		"body": [
			"ll D[NT];",
			"vector<pii> Graf[NT];",
			"priority_queue<pli> Q;",
			"",
			"void Dijkstra(int v, int n) {",
			"\tFOR(i, 1, n) D[i] = INF;",
			"\tD[v] = 0;",
			"\tQ.push({0, v});",
			"\twhile(!Q.empty()) {",
			"\t\tv = Q.top().nd;",
			"\t\tll dist = -Q.top().st;",
			"\t\tQ.pop();",
			"\t\tif(dist > D[v])",
			"\t\t\tcontinue;",
			"\t\tTRAV(x, Graf[v]) {",
			"\t\t\tauto [u, c] = x;",
			"\t\t\tif(D[v] + c < D[u]) {",
			"\t\t\t\tD[u] = D[v] + c;",
			"\t\t\t\tQ.push({-D[u], u});",
			"\t\t\t}",
			"\t\t}",
			"\t}",
			"}"
		],
		"description": "Cpp template"
	},
	"LCA": {
		"prefix": "lca",
		"body": [
			"int Anc[NT][LOG + 1], Pre[NT], Post[NT], idx;",
			"",
			"void Ancestors(int v, int p) {",
			"\tAnc[v][0] = p;",
			"\tFOR(k, 1, LOG) {",
			"\t\tAnc[v][k] = Anc[ Anc[v][k - 1] ][k - 1];",
			"\t}",
			"\tidx++;",
			"\tPre[v] = idx;",
			"\tTRAV(u, Graf[v]) {",
			"\t\tif(u != p) Ancestors(u, v);",
			"\t}",
			"\tPost[v] = idx;",
			"}",
			"",
			"bool Przodek(const int &a, const int &b) { // czy a jest przodkiem b",
			"\treturn Pre[a] <= Pre[b] and Pre[b] <= Post[a];",
			"}",
			"",
			"int Lca(int a, int b) {",
			"\tif(Przodek(a, b)) return a;",
			"\tif(Przodek(b, a)) return b;",
			"\tFORD(k, 0, LOG) {",
			"\t\tif(!Przodek(Anc[a][k], b))",
			"\t\t\ta = Anc[a][k];",
			"\t}",
			"\treturn Anc[a][0];",
			"}"
		],
		"description": "Cpp template"
	},
