	"Drzewo PunktPrzedzial": {
		"prefix": "treepntseg",
		"body": [
			"void Update(int v, int val) {",
			"\tv += ntree - 1;",
			"\tT[v] = val;",
			"\tv >>= 1;",
			"\twhile(v) {",
			"\t\tT[v] = max(T[lc], T[rc]);",
			"\t\tv >>= 1;",
			"\t}",
			"}",
			"",
			"ll Query(int l, int r) {",
			"\tl += ntree - 1; r += ntree - 1;",
			"\tll ans = T[l];",
			"\tif(r > l) ans = max(ans, T[r]);",
			"\twhile(r - l > 1) {",
			"\t\tif(!(l&1)) ans = max(ans, T[l + 1]);",
			"\t\tif(r&1) ans = max(ans, T[r - 1]);",
			"\t\tl >>= 1; r >>= 1;",
			"\t}",
			"\treturn ans;",
			"}"
		],
		"description": "Cpp template"
	},
